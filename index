<nav id="nav">
  <div class="nav-inner">
    <a href="#" class="nav-logo">
      <img src="data:image/jpeg;base64," alt="Pontelia">
      <span>Pontelia</span>
    </a>
    <ul class="nav-links">
      <li><a href="#who">Who it's for</a></li>
      <li><a href="#helps">What it does</a></li>
      <li><a href="#how">How it works</a></li>
      <li><a href="https://chatgpt.com/g/g-69c5961fdc1c81919f62b1c552d127b7-pontelia" target="_blank" rel="noopener" class="btn btn-primary">Start Planning</a></li>
    </ul>
    <button class="mobile-menu-btn" aria-label="Menu">
      <span></span><span></span><span></span>
