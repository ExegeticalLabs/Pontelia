<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pontelia — Sustainable Planning for Disability Care</title>
<meta name="description" content="Pontelia is a free AI planning assistant helping families, disabled adults, and support professionals move from fragile, informal care toward sustainable, documented support arrangements.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400;1,9..144,600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --navy: #001A33;
  --navy-mid: #0A2540;
  --teal: #59D5D1;
  --teal-deep: #3BBFBB;
  --teal-soft: #E6F8F7;
  --teal-glow: rgba(89, 213, 209, 0.12);
  --warm-bg: #FAFBFC;
  --card-bg: #F4F6F8;
  --text-primary: #001A33;
  --text-secondary: #4A5C6E;
  --text-muted: #7B8FA0;
  --border: #E5E9ED;
  --white: #FFFFFF;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
  color: var(--text-primary);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  line-height: 1.6;
}

/* ─── TYPOGRAPHY ─── */
.display { font-family: 'Fraunces', Georgia, serif; }

/* ─── NAV ─── */
nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 72px;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.3s;
}

nav.scrolled { box-shadow: 0 1px 12px rgba(0, 26, 51, 0.06); }

.nav-inner {
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  text-decoration: none;
}

.nav-logo img {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  object-fit: cover;
}

.nav-logo span {
  font-weight: 800;
  font-size: 1.3rem;
  color: var(--navy);
  letter-spacing: -0.02em;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  list-style: none;
}

.nav-links a {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--navy); }

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-family: inherit;
  font-weight: 700;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-primary {
  background: var(--teal);
  color: var(--navy);
  padding: 0.7rem 1.6rem;
  border-radius: 50px;
  font-size: 0.9rem;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(89, 213, 209, 0.35);
}

.btn-hero {
  padding: 1.1rem 2.4rem;
  font-size: 1.05rem;
  border-radius: 56px;
}

.btn-hero svg { width: 18px; height: 18px; transition: transform 0.2s; }
.btn-hero:hover svg { transform: translateX(3px); }

.btn-outline {
  background: transparent;
  color: var(--text-secondary);
  border: 2px solid var(--border);
  padding: 1rem 2rem;
  border-radius: 56px;
  font-size: 1.05rem;
}

.btn-outline:hover {
  border-color: var(--teal);
  color: var(--navy);
  background: var(--teal-glow);
}

.mobile-menu-btn {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
}

.mobile-menu-btn span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--navy);
  margin: 5px 0;
  border-radius: 2px;
}

/* ─── HERO ─── */
.hero {
  padding: 10rem 2rem 6rem;
  background: linear-gradient(180deg, var(--warm-bg) 0%, var(--white) 100%);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -15%;
  width: 60vw;
  height: 60vw;
  background: radial-gradient(circle, rgba(89, 213, 209, 0.06) 0%, transparent 65%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 5rem;
  align-items: center;
}

.hero-text { position: relative; z-index: 1; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.4rem 0.9rem;
  background: var(--teal-soft);
  border-radius: 50px;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--teal-deep);
  margin-bottom: 2rem;
}

.hero-badge::before {
  content: '';
  width: 7px;
  height: 7px;
  background: var(--teal);
  border-radius: 50%;
}

h1 {
  font-family: 'Fraunces', Georgia, serif;
  font-size: clamp(2.6rem, 5vw, 3.8rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.025em;
  color: var(--navy);
  margin-bottom: 1.6rem;
}

h1 em {
  color: var(--teal-deep);
  font-style: italic;
}

.hero-sub {
  font-size: 1.15rem;
  line-height: 1.75;
  color: var(--text-secondary);
  max-width: 500px;
  margin-bottom: 2.5rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.hero-trust {
  margin-top: 2.5rem;
  font-size: 0.82rem;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.hero-trust::before {
  content: '';
  width: 28px;
  height: 2px;
  background: var(--teal);
  border-radius: 2px;
}

/* Hero visual */
.hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.logo-container {
  position: relative;
  width: 100%;
  max-width: 480px;
}

.logo-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 380px;
  height: 380px;
  background: radial-gradient(circle, rgba(89, 213, 209, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  animation: breathe 5s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(1.06); opacity: 0.65; }
}

.logo-img {
  position: relative;
  z-index: 1;
  width: 100%;
  /* No border-radius or shadow — blend into page */
  -webkit-mask-image: radial-gradient(ellipse 70% 65% at 50% 45%, black 50%, transparent 100%);
  mask-image: radial-gradient(ellipse 70% 65% at 50% 45%, black 50%, transparent 100%);
}

/* ─── SECTIONS ─── */
section { padding: 6rem 2rem; }

.section-inner {
  max-width: 1200px;
  margin: 0 auto;
}

.section-label {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--teal-deep);
  margin-bottom: 0.8rem;
}

h2 {
  font-family: 'Fraunces', Georgia, serif;
  font-size: clamp(1.8rem, 3.2vw, 2.6rem);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--navy);
  margin-bottom: 1rem;
}

.section-sub {
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--text-secondary);
  max-width: 560px;
}

/* ─── WHO IT'S FOR ─── */
.who { background: var(--warm-bg); }

.who-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.25rem;
  margin-top: 3rem;
}

.who-card {
  background: var(--white);
  border-radius: 20px;
  padding: 2rem 1.8rem;
  border: 1px solid var(--border);
  transition: all 0.3s ease;
}

.who-card:hover {
  transform: translateY(-4px);
  border-color: var(--teal);
  box-shadow: 0 8px 32px rgba(0, 26, 51, 0.06);
}

.who-icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: var(--teal);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.2rem;
}

.who-icon svg { width: 22px; height: 22px; color: var(--navy); }

.who-card h3 {
  font-size: 1.08rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.who-card p {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text-secondary);
}

/* ─── HELPS ─── */
.helps { background: var(--white); }

.helps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 1.25rem;
  margin-top: 3rem;
}

.help-card {
  display: flex;
  gap: 1.1rem;
  padding: 1.5rem 1.6rem;
  border-radius: 16px;
  background: var(--card-bg);
  border: 1px solid transparent;
  transition: all 0.3s ease;
}

.help-card:hover {
  background: var(--white);
  border-color: var(--teal);
  box-shadow: 0 4px 18px rgba(0, 26, 51, 0.05);
}

.help-num {
  font-family: 'Fraunces', serif;
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--teal);
  line-height: 1;
  min-width: 30px;
  padding-top: 0.1rem;
}

.help-card h3 {
  font-size: 0.98rem;
  font-weight: 700;
  margin-bottom: 0.3rem;
}

.help-card p {
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--text-secondary);
}

/* ─── BRIDGE STEPS ─── */
.bridge { background: var(--warm-bg); }

.bridge-steps {
  max-width: 720px;
  margin: 3rem auto 0;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.bridge-step {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  background: var(--white);
  padding: 2rem;
  border-radius: 20px;
  border: 1px solid var(--border);
  transition: all 0.3s ease;
}

.bridge-step:hover {
  border-color: var(--teal);
  box-shadow: 0 6px 24px rgba(0, 26, 51, 0.05);
}

.step-num {
  width: 52px;
  height: 52px;
  min-width: 52px;
  border-radius: 50%;
  background: var(--navy);
  color: var(--teal);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Fraunces', serif;
  font-size: 1.3rem;
  font-weight: 800;
}

.bridge-step h3 {
  font-size: 1.12rem;
  font-weight: 700;
  margin-bottom: 0.35rem;
}

.bridge-step .voice {
  font-style: italic;
  color: var(--text-muted);
  font-size: 0.88rem;
  margin-bottom: 0.5rem;
}

.bridge-step p {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text-secondary);
}

/* ─── SCENARIOS ─── */
.scenarios { background: var(--white); }

.scenarios-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.25rem;
  margin-top: 3rem;
}

.scenario-card {
  background: var(--card-bg);
  border-radius: 20px;
  padding: 2rem;
  border: 1px solid transparent;
  transition: all 0.3s;
}

.scenario-card:hover {
  border-color: rgba(89, 213, 209, 0.3);
  background: var(--white);
  box-shadow: 0 6px 24px rgba(0, 26, 51, 0.04);
}

.scenario-quote {
  font-family: 'Fraunces', serif;
  font-size: 1.02rem;
  font-style: italic;
  line-height: 1.6;
  color: var(--navy);
  margin-bottom: 1.2rem;
  padding-left: 1.1rem;
  border-left: 3px solid var(--teal);
}

.scenario-tag {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--teal-deep);
}

/* ─── PRINCIPLES ─── */
.principles {
  background: var(--navy);
  position: relative;
  overflow: hidden;
}

.principles::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -15%;
  width: 50vw;
  height: 50vw;
  background: radial-gradient(circle, rgba(89, 213, 209, 0.06) 0%, transparent 60%);
  border-radius: 50%;
}

.principles .section-label { color: var(--teal); }
.principles h2 { color: var(--white); }
.principles .section-sub { color: rgba(255, 255, 255, 0.55); }

.principles-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.25rem;
  margin-top: 3rem;
}

.principle-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 20px;
  padding: 2rem;
  transition: all 0.3s;
}

.principle-card:hover {
  background: rgba(255, 255, 255, 0.07);
  border-color: rgba(89, 213, 209, 0.2);
  transform: translateY(-3px);
}

.principle-card h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--teal);
  margin-bottom: 0.5rem;
}

.principle-card p {
  font-size: 0.88rem;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.5);
}

/* ─── CTA ─── */
.cta-section { padding: 5rem 2rem; background: var(--white); }

.cta-box {
  max-width: 1000px;
  margin: 0 auto;
  background: var(--navy);
  border-radius: 32px;
  padding: 5rem 3rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.cta-box::before, .cta-box::after {
  content: '';
  position: absolute;
  width: 250px;
  height: 250px;
  background: var(--teal);
  opacity: 0.08;
  border-radius: 50%;
  filter: blur(80px);
}

.cta-box::before { top: -80px; right: -60px; }
.cta-box::after { bottom: -80px; left: -60px; }

.cta-box h2 {
  color: var(--white);
  margin-bottom: 1rem;
  position: relative;
  z-index: 1;
}

.cta-box p {
  color: rgba(255, 255, 255, 0.6);
  font-size: 1.08rem;
  line-height: 1.7;
  max-width: 520px;
  margin: 0 auto 2.5rem;
  position: relative;
  z-index: 1;
}

.cta-box .btn-primary {
  position: relative;
  z-index: 1;
  padding: 1.1rem 2.4rem;
  font-size: 1.05rem;
}

.cta-note {
  margin-top: 1.2rem;
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.35);
  position: relative;
  z-index: 1;
}

/* ─── FOOTER ─── */
footer {
  background: var(--white);
  border-top: 1px solid var(--border);
  padding: 4rem 2rem;
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}

.footer-brand img {
  width: 30px;
  height: 30px;
  border-radius: 8px;
}

.footer-brand span {
  font-weight: 800;
  font-size: 1.1rem;
  color: var(--navy);
}

.footer-tagline {
  font-size: 0.92rem;
  color: var(--text-muted);
  margin-bottom: 2rem;
  max-width: 500px;
}

.disclaimer {
  padding: 1.5rem 2rem;
  background: var(--card-bg);
  border-radius: 16px;
  max-width: 720px;
  border: 1px solid var(--border);
  margin-bottom: 2rem;
}

.disclaimer strong {
  display: block;
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 0.4rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.disclaimer p {
  font-size: 0.78rem;
  line-height: 1.65;
  color: var(--text-muted);
}

.footer-meta {
  font-size: 0.78rem;
  color: var(--text-muted);
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.footer-meta a {
  color: var(--teal-deep);
  text-decoration: none;
  font-weight: 600;
  transition: color 0.2s;
}

.footer-meta a:hover { color: var(--navy); }

/* ─── SCROLL REVEAL ─── */
.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.65s cubic-bezier(0.22, 1, 0.36, 1);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Hero animation */
.fade-in { animation: fadeIn 0.7s ease-out both; }
.fade-in-d1 { animation: fadeIn 0.7s ease-out 0.1s both; }
.fade-in-d2 { animation: fadeIn 0.7s ease-out 0.2s both; }
.fade-in-d3 { animation: fadeIn 0.7s ease-out 0.35s both; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: 3rem;
    text-align: center;
  }
  .hero-sub { margin-left: auto; margin-right: auto; }
  .hero-actions { justify-content: center; }
  .hero-trust { justify-content: center; }
  .hero-visual { order: -1; }
  .logo-container { max-width: 320px; }
  .nav-links { display: none; }
  .mobile-menu-btn { display: block; }
  .helps-grid { grid-template-columns: 1fr; }
}

@media (max-width: 600px) {
  section { padding: 4rem 1.2rem; }
  .hero { padding: 8rem 1.2rem 4rem; }
  .hero-actions { flex-direction: column; width: 100%; }
  .hero-actions .btn { width: 100%; }
  .cta-box { padding: 3rem 1.5rem; border-radius: 24px; }
  .bridge-step { flex-direction: column; gap: 1rem; }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .reveal { opacity: 1; transform: none; transition: none; }
  .fade-in, .fade-in-d1, .fade-in-d2, .fade-in-d3 { animation: none; opacity: 1; transform: none; }
  .logo-glow { animation: none; }
  * { transition-duration: 0.01ms !important; }
}
</style>
</head>
<body>

