  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-badge fade-in">A calm path forward</div>
      <h1 class="fade-in-d1">Planning for a future that doesn't depend on <em>luck</em>.</h1>
      <p class="hero-sub fade-in-d2">Pontelia is a free AI assistant for families, disabled adults, and professionals moving from fragile, informal care toward sustainable, documented support systems.</p>
      <div class="hero-actions fade-in-d3">
        <a href="https://chatgpt.com/g/g-69c5961fdc1c81919f62b1c552d127b7-pontelia" target="_blank" rel="noopener" class="btn btn-primary btn-hero">
          Meet Your Planning Assistant
